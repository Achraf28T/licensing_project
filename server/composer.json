{
    "name": "mycompany/licensing-server",
    "description": "Licensing server in PHP/Symfony",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "^6.0",
        "symfony/http-kernel": "^6.0",
        "symfony/routing": "^6.0",
        "symfony/http-foundation": "^6.0",
        "symfony/orm-pack": "^2.0",
        "symfony/console": "^6.0",
        "symfony/uid": "^6.0",
        "doctrine/orm": "^2.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true
        }
    }
}